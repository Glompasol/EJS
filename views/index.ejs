<%- include("partials/header") %>

<h1><%= title %></h1>

<% if (typeof message !== "undefined" && message) {%>
  <div class="notice"><%=message%>/div>
<%}

<section class="card">
  <h2>Legg til sang</h2>
  <form action="/songs" method="POST" class="form">
      <label for="title">Sangtittel</label>
      <input id="title" name="title" type="text" required />

      <label for="artist">Artist</label>
      <input id="artist" name="artist" type="text" required />

      <label for="listened_date">Dato (YYYY-MM-DD)</label>
      <input id="listened_date" name="listened_date" type="date" required />

      <button type="submit">Lagre sang</button>
  </form>
  <p class="muted">Dato lagres i format YYYY-MM-DD.</p>
</section>

<section class="card">
  <h2>Registrerte sanger</h2>
  <ul>
    <% if (songs.length === 0) {%>
      <li>(Ingen sanger enda)</li>
    <%}
    <% for (const s of songs) {%>
      <li>
        <strong><%= s.title %></strong> av <em><%= s.artist %</em>
        <span class="muted">- <%= s.listened_date %></span>
      </li>
    <% } %>
  </ul>
</section>

<%- include("partials/footer") %>