<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forum</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header>
        <h1>Forum</h1>
        <nav>
            <a href="/login">Logg inn</a>
            <a href="/register">Registrer</a>
        </nav>
    </header>

    <main>
        <aside>
            <h2>Kanaler</h2>
            <ul>
                <li><a href="/channel/general"># general</a></li>
                <li><a href="/channel/tech"># tech</a></li>
                <li><a href="/channel/random"># random</a></li>
            </ul>
        </aside>

        <section>
            <h2># general</h2>

            <div class="messages">
                <% messages.forEach(message => { %>
                    <div class="message">
                        <strong><%= message.username %></strong>
                        <p><%= message.content %></p>
                    </div>
                <% }) %>
            </div>

            <form action="/message" method="POST">
                <input type="text" name="content" placeholder="Skriv en melding..." required>
                <button type="submit">Send</button>
            </form>
        </section>
    </main>

</body>
</html>